#####################################################################
# Android XR xtrace
#
# A Perfetto tracing tool.
# - Good defaults for Android XR performance analysis.
# - Handy GPU and CPU thread per-frame usage stats.
# - Can trace an attached adb device or the local PC.
#
# Installation:
# - Unzip xtrace package somewhere.
# - Add the location of this xtrace script to your PATH.
#
# Requirements:
# - bash environment (ie: Git Bash or MSys on Windows).
# - python (for auto-open feature).
# - perl


export MSYS_NO_PATHCONV=1

available_atrace_categories() {
  echo $(adb shell atrace --list 2> /dev/null | sed -r 's/ *(.*) - .*/\1/g')
}

is_adb_root() {
  if [[ -z "${_IS_ROOTED_STATUS}" ]]; then
    adb root > /dev/null 2>&1
    if adb shell 'su 0 whoami' 2> /dev/null | grep -q 'root'; then
      _IS_ROOTED_STATUS=true
    else
      _IS_ROOTED_STATUS=false
    fi
  fi

  [[ "${_IS_ROOTED_STATUS}" == true ]]
}

# echo if adb device is rooted.
ecRT() {
  if is_adb_root; then
    echo "$@"
  fi
}

# echo if adb device is unrooted.
ecNR() {
  if ! is_adb_root; then
    echo "$@"
  fi
}

show_help_and_exit() {
  echo "syntax: xtrace [options] [atrace categories] [perfetto categories] [ftrace sources]"
  echo ""
  echo "Configure device tracing options:"
  echo "  (no tracing is done with these options)"
  echo "  [--info]                 Print device build and GPU info"
  ecNR "  [--enable-gpu]           Enable GPU tracing on the device."
  ecNR "                           Note: Restart the app and then trace with --gpu1 or --gpu2."
  ecNR "  [--disable-gpu]          Disable GPU tracing on the device"
  ecRT "  [--enable-gpu]           Enable high-res GPU tracing (--gpu2) on the device and restart services"
  ecRT "  [--disable-gpu]          Disable GPU tracing on the device and restart services"
  ecRT "  [--enable-gpu-no-stop]   Enable high-res GPU tracing (--gpu2) without restarting services"
  ecRT "  [--disable-gpu-no-stop]  Disable GPU tracing without restarting services"
  ecRT "  [--disable-dynamic-policy]  [XR] Disable dynamic policy and restart services"
  ecRT "  [--disable-gpu-preemption]  [XR] Disable compositor preemption and restart services"
  ecRT "  [--lock-head]            [XR] Lock to a fake head pose"
  ecRT "  [--unlock-head]          [XR] Unlock the head pose"
  echo "  [--screen-timeout <ms>]  Set screen timeout and wake up the device. <ms> can be"
  echo "                           an integer ms or a duration string like 1h20m."
  ecNR "                           Note: proximity sensor must be touched to wake device."
  echo ""
  echo "Processing options:"
  echo "  [-f /path/to/trace]      Load existing trace file instead of recording a trace"
  echo "  [--big]                  Load trace via trace_processor_shell (required for ~300MB+)"
  echo "  [-q /path/to/query.sql]  Run the given perfetto SQL query on trace output"
  echo "  [--ui-query query.sql]   Run the given SQL query in the Perfetto UI (not compatible with --big)"
  echo "  [--csv-output]           Output unfiltered CSV for SQL queries"
  echo "  [--verbose-sql-logs]     Show verbose perfetto trace parsing logs during SQL query"
  echo "  [--frame-stats]          Print frame stats (on by default)"
  echo "  [--no-frame-stats]       Do not print frame stats"
  echo "  [--surface-stats]        Print GPU surface stats"
  echo "  [--no-surface-stats]     Do not print GPU surface stats"
  echo "  [--counter-stats]        Print detailed GPU counter stats for a target process and surface."
  echo "                           This requires a trace with --gpu2 --counters."
  echo "                           Usage: --counter-stats[=<app_name>,<surface_index>/<total_surfaces>]"
  echo "                           Examples: --counter-stats=com.company.app,1/2 or --counter-stats=2/2"
  echo "                             --counter-stats alone auto-selects the most costly GPU surface"
  echo "  [--no-counter-stats]     Do not print GPU counter stats"
  echo "  [--top]                  Print the top CPU usage by process"
  echo "  [--no-open]              Do not open the trace in the browser"
  echo "  [--verbose]              Print verbose output"
  echo "  [--avg <event_name>]     Print average duration in MS of given slice event along with frame-stats"
  echo "                           Note: Wildcard is %. \"@\" characters must be escaped."
  echo "                           Note: Duration is wall-clock-based, not thread run/sleep based."
  echo ""
  echo "Trace recording options:"
  echo "  [--local]                Trace local OS instead of adb device (requires perfetto instrumentation)."
  echo "  [-t <duration_ms>]       Duration to trace (default is until Ctrl-C). Also supports h/m/s suffix:"
  echo "                           Examples: \"1m5s\" (1 minute + 5 seconds) or \"300\" (300 ms)"
  echo "  [-o <output_file_or_dir>]  Write trace to a file or directory"
  echo "  [-b <buffer_size_kb>]    Size of trace buffer in KB (default is ${buffer_size_kb})"
  echo "  [-p /path/to/perfetto]   Path to perfetto tool if it's not in \$PATH"
  echo "  [-c /path/to/config]     Use existing textproto config file instead of generating it"
  echo "  [-i <period_ms>]         Incremental update period in ms"
  echo "  [--screenshot]           [XR] Capture a raw screenshot alongside the trace"
  ecRT "  [--lock-frequencies]     [XR] Lock CPU, GPU and DDR frequencies for more consistent measurements."
  ecRT "                           Note: Performance will be different from normal device conditions. This"
  ecRT "                            option is useful for A/B testing different CPU or GPU code to measure"
  ecRT "                            which is faster."
  ecRT "                           Note: Dynamic Policy can override the locked frequencies in some cases,"
  ecRT "                            such as during app transitions. For best results, start the trace after"
  ecRT "                            the target app is already running."
  ecRT "  [--gpu]                  Include kgsl ftrace GPU data (on by default)"
  echo "  [--gpu1]                 Include GPU slice events and GPU frame stats"
  echo "  [--gpu2]                 Include detailed GPU events (has significant GPU overhead)"
  echo "  [--counters]             Include GPU counters (combine with --gpu2 for best results)"
  echo "  [--vk]                   Include Vulkan API tracing"
  echo "  [--no-ftrace]            Do not include common ftrace data"
  echo "  [--no-atrace]            Do not include common atrace categories"
  echo "  [--no-perfetto]          Do not include common perfetto categories"
  echo "  [--no-atrace-apps]       Do not include atrace from all apps (default)"
  echo "  [--atrace-apps <app>]    Include atrace from <app> (\"*\" for all apps). Note this has very high"
  echo "                           CPU impact for apps with high frequency events (such as Unity Development"
  echo "                           builds), invalidating overall frame timing."
  echo "  [--binary-config]        Send binary config instead of text (requires protoc)"
  echo "  [--write-args <file>]    Write key args to <file> for use as title"
  echo "  [-d <category>] ...      Disabled categories"
  echo "  [<category>] ...         Enabled perfetto or atrace categories"
  echo "  [<ftrace category>] ...  Enabled ftrace categories, must contain / character (ie: kmem/rss_stat)"
  echo ""
  echo "Examples:"
  echo "  xtrace                           Trace adb device until Ctrl-C"
  echo "  xtrace -t 1s                     Trace for 1 second"
  echo "  xtrace --gpu2 --counters         Trace detailed GPU events and counters"
  echo "  xtrace gfx                       Include gfx category (disabled-by-default)"
  echo '  xtrace -d "*" wm gfx             Only trace wm and gfx'
  echo "  xtrace -f ./trace                Open ./trace in browser"
  echo "  xtrace -f ./trace -q ./query     Run SQL query on ./trace"
  echo "  xtrace --big -b 500000           Record and view a big trace"
  echo "  xtrace --big -f ./trace          Open big trace in browser"
  echo '  xtrace --atrace-apps "*"         Include all atrace apps events'
  echo "  xtrace --avg %doFrame%           Show average durations of slice events matching *doFrame*"
  echo ""
  echo "--frame-stats output:"
  echo "  Note: CPU and GPU usage is based on runtime durations, ignoring frequency."
  echo "  W H: Width, height of framebuffer (when available)"
  echo "  GpuMSPF: GPU usage in ms per frame."
  echo "  FPS: Frames per second."
  echo "  Frames: Total submitted frame count."
  echo "  Drops: Total frame drops."
  echo "  DropsPM: Frame drops per minute."
  echo "  CpuMSPF: Total CPU usage of the process in ms per frame."
  echo "  TopThread1 TopThread2: The top two threads by CPU usage."
  echo "  MSPF1 MSPF2: CPU usage of the top two threads in ms per frame."
  echo "  Dur: Duration in seconds that the process executed frames."
  echo "  GpuFreq: Average GPU frequency during the trace (not per process)."
  echo "  Watts: Average power usage in watts of the whole system (not per process)."
  echo ""
  echo "--top output:"
  echo "  Note: CPU usage is based on durations, ignoring CPU frequency."
  echo "  Rank: Process rank ordered by total CPU usage."
  echo "  GpuPct: Percent GPU core usage (100 * GPU running duration / trace duration)."
  echo "  CpuPct: Percent CPU core usage (100 * CPU running duration / trace duration)."
  echo "  TopThread1 TopThread2: The top two threads by CPU usage."
  echo "  CpuPct1 CpuPct2: Percent CPU core usage of the top two threads."
  echo ""
  echo "Special categories:"
  echo "  chrome.*: Chrome trace categories (\"chrome.\" prefix is removed)"
  echo "  Chrome gfx: chrome.ui chrome.cc chrome.gpu"
  echo "  Android gfx: gfx view wm"
  echo ""
  echo "Available Android categories:"
  echo "  $(available_atrace_categories)" | tr '\n' ' '
  exit 1
}

cpu=$(uname -m)
os=$(uname -o)

# Use python3 if it exists, otherwise python.
python=python
python3 -c quit > /dev/null 2>&1 && python=python3

xtrace_dir=$(dirname "$0")

bg_bash="bash -mc"
if [[ "${os}" = "Msys" ]]; then
  host_tools_dir="${xtrace_dir}/third_party/perfetto/windows-amd64"
  bg_bash="mintty bash -mc"
elif [[ "${os}" = "Darwin" ]] && [[ "${cpu}" = "x86_64" ]]; then
  host_tools_dir="${xtrace_dir}/third_party/perfetto/mac-amd64"
elif [[ "${os}" = "Darwin" ]]; then
  host_tools_dir="${xtrace_dir}/third_party/perfetto/mac-arm64"
else
  host_tools_dir="${xtrace_dir}/third_party/perfetto/linux-amd64"
fi

data_dir="${xtrace_dir}/data/adreno"

if [[ "${os}" = "Msys" ]]; then
  cygpathw='cygpath -w'
else
  cygpathw='echo'
fi

push_config=true
use_binary_config=false
auto_open=true
screenshot=false
lock_frequencies=false
lock_head=''
enable_gpu=false
enable_gpu_restart_services=true
disable_gpu=false
disable_gpu_restart_services=true
screen_timeout_ms=0
skip_tracing=false
include_gpu=false
include_gpu2=false
gpu2_low_overhead=false
include_counters=false
include_renderstage_counters=false
include_android_thermal_config=false
sql_path=''
ui_sql_path=""
gpu_stats_filename="gpu_stats2.sql"
custom_stats=()
print_frame_stats=true
print_surface_stats=false
suppress_surface_stats=false
print_gpu_counter_stats=false
print_cpu_top=false
gpu_starting_freq_khz=0
is_filtered_query_output=true
verbose_sql_logs=false
is_local=false
is_android=true
time_ms=0
include_ftrace_defaults=true
include_atrace_defaults=true
include_perfetto_defaults=true
symbolize_ksyms=false
atrace_apps=()
ftrace_events=()
categories=()
chrome_categories=''
disabled_categories=()
chrome_disabled_categories=''
now=$(date +"%Y-%m-%d_%H-%M-%S")
from_file=false
is_big=false
output_file=''
trace_input_files=()
is_compare=false
config_filename="perfetto-${RANDOM}.config"
config_filepath="/tmp/${config_filename}"
use_existing_config=false
output_args_file=''
title_args=()
perfetto="${host_tools_dir}/perfetto"
incremental_update_period_ms=1000
buffer_size_kb=200000
fill_policy=RING_BUFFER
verbose_logs=false
verbose_err="/dev/null"
is_quiet=false

# See /vendor/bin/gpu_counter_producer or /system/bin/gpu_counter_producer on supported devices.
gpu_counter_producer="gpu_counter_producer"
gpu_trace_metrics_path="${data_dir}/all_gpu_trace_metrics.list"
ui_gpu1_cmds_path="${data_dir}/ui_gpu1.cmds"
ui_gpu2_cmds_path="${data_dir}/ui_gpu2.cmds"
ui_kgsl_cmds_path="${data_dir}/ui_kgsl.cmds"

duration_to_ms() {
  local duration="$1"
  local ms=$(($(echo "${duration}" | sed 's/h/*3600000+/g; s/m/*60000+/g; s/s/*1000+/g' | sed 's/+$/ /g')))
  echo "${ms}"
}

verbose() {
  if [[ "${verbose_logs}" == true ]]; then
    echo "$1"
  fi
}

notquiet() {
  if [[ "${is_quiet}" == false ]]; then
    echo "$1"
  fi
}

# Print dashed line matching length of first line of $1
dashed_header_line() {
  local first_line=$(head -n 1 <<< "$1")
  local dash_line=""
  printf -v dash_line '%*s' "${#first_line}" ''
  notquiet "${dash_line// /-}"
}

# Parse args
args=("$@")

num_args="${#args[@]}"
for (( i = 0; i < num_args; i++ )); do
  if [[ "${args[${i}]}" = "--help" ]]; then
    show_help_and_exit
  elif [[ "${args[${i}]}" = "--local" ]]; then
    is_local=true
  elif [[ "${args[${i}]}" = "-t" ]]; then
    i=$((i+1))
    time_ms=$(duration_to_ms "${args[${i}]}")
    fill_policy=DISCARD
  elif [[ "${args[${i}]}" = "--big" ]]; then
    is_big=true
  elif [[ "${args[${i}]}" = "--compare" ]]; then
    is_compare=true
  elif [[ "${args[${i}]}" = "-f" ]]; then
    i=$((i+1))
    output_file=$($cygpathw "${args[${i}]}")
    trace_input_files+=("${output_file}")
    from_file=true
  elif [[ "${args[${i}]}" = "-o" ]]; then
    i=$((i+1))
    output_file=$($cygpathw "${args[${i}]}")
  elif [[ "${args[${i}]}" = "-b" ]]; then
    i=$((i+1))
    buffer_size_kb="${args[${i}]}"
  elif [[ "${args[${i}]}" = "-p" ]]; then
    i=$((i+1))
    perfetto="${args[${i}]}"
  elif [[ "${args[${i}]}" = "-i" ]]; then
    i=$((i+1))
    incremental_update_period_ms="${args[${i}]}"
  elif [[ "${args[${i}]}" = "-q" ]]; then
    i=$((i+1))
    sql_path="${args[${i}]}"
  elif [[ "${args[${i}]}" = "--ui-query" ]]; then
    i=$((i+1))
    ui_sql_path="$($cygpathw "${args[${i}]}")"
  elif [[ "${args[${i}]}" = "--csv-output" ]]; then
    is_filtered_query_output=false
  elif [[ "${args[${i}]}" = "--verbose-sql-logs" ]]; then
    verbose_sql_logs=true
  elif [[ "${args[${i}]}" = "--frame-stats" ]]; then
    print_frame_stats=true
  elif [[ "${args[${i}]}" = "--no-frame-stats" ]]; then
    print_frame_stats=false
  elif [[ "${args[${i}]}" == "--surface-stats" ]]; then
    print_surface_stats=true
  elif [[ "${args[${i}]}" == "--no-surface-stats" ]]; then
    suppress_surface_stats=true
  elif [[ "${args[${i}]}" == --counter-stats* ]]; then
    print_gpu_counter_stats=true
    if [[ "${args[${i}]}" == *=* ]]; then
      gpu_counter_stats_filter="${args[${i}]#*=}"
    fi
  elif [[ "${args[${i}]}" = "--avg" ]]; then
    i=$((i+1))
    custom_stats+=("${args[${i}]}")
  elif [[ "${args[${i}]}" = "--top" ]]; then
    print_cpu_top=true
  elif [[ "${args[${i}]}" = "-d" ]]; then
    i=$((i+1))
    cat="${args[${i}]}"
    if [[ "${cat}" == chrome.* ]]; then
      chrome_disabled_categories+="\\\"${cat#"chrome."}\\\","
    else
      disabled_categories+=("${cat}")
    fi
  elif [[ "${args[${i}]}" = "--write-args" ]]; then
    i=$((i+1))
    output_args_file="${args[${i}]}"
  elif [[ "${args[${i}]}" = "--info" ]]; then
    adb shell getprop ro.build.description
    adb shell dumpsys SurfaceFlinger | grep GLES
    skip_tracing=true
  elif [[ "${args[${i}]}" = "--enable-gpu" ]]; then
    enable_gpu=true
    skip_tracing=true
  elif [[ "${args[${i}]}" = "--enable-gpu-no-stop" ]]; then
    enable_gpu=true
    enable_gpu_restart_services=false
    skip_tracing=true
  elif [[ "${args[${i}]}" = "--disable-gpu" ]]; then
    disable_gpu=true
    skip_tracing=true
  elif [[ "${args[${i}]}" = "--disable-gpu-no-stop" ]]; then
    disable_gpu=true
    disable_gpu_restart_services=false
    skip_tracing=true
  elif [[ "${args[${i}]}" = "--disable-dynamic-policy" ]]; then
    disable_dynamic_policy=true
    skip_tracing=true
  elif [[ "${args[${i}]}" = "--disable-gpu-preemption" ]] && is_adb_root; then
    disable_gpu_preemption=true
    skip_tracing=true
  elif [[ "${args[${i}]}" = "--lock-head" ]]; then
    lock_head="1"
    skip_tracing=true
  elif [[ "${args[${i}]}" = "--unlock-head" ]]; then
    lock_head="0"
    skip_tracing=true
  elif [[ "${args[${i}]}" = "--screen-timeout" ]]; then
    i=$((i+1))
    screen_timeout_ms=$(duration_to_ms "${args[${i}]}")
    skip_tracing=true
  elif [[ "${args[${i}]}" = "--screenshot" ]]; then
    screenshot=true
  elif [[ "${args[${i}]}" = "--lock-frequencies" ]]; then
    lock_frequencies=true
  elif [[ "${args[${i}]}" = "--gpu" ]]; then
    include_gpu=true
    title_args+=("gpu")
  elif [[ "${args[${i}]}" = "--gpu2" ]]; then
    include_gpu=true
    include_gpu2=true
    title_args+=("gpu2")
  elif [[ "${args[${i}]}" = "--gpu1" ]]; then
    include_gpu=true
    include_gpu2=true
    gpu2_low_overhead=true
    title_args+=("gpu1")
  elif [[ "${args[${i}]}" = "--counters" ]]; then
    include_counters=true
    title_args+=("counters")
  elif [[ "${args[${i}]}" = "--vk" ]]; then
    include_vulkan=true
    title_args+=("vk")
  elif [[ "${args[${i}]}" = "--no-atrace-apps" ]]; then
    atrace_apps=()
    title_args+=("no-atrace-apps")
  elif [[ "${args[${i}]}" = "--atrace-apps" ]]; then
    i=$((i+1))
    atrace_apps+=("${args[${i}]}")
    title_args+=("atrace-apps")
  elif [[ "${args[${i}]}" = "--no-open" ]]; then
    auto_open=false
  elif [[ "${args[${i}]}" = "--quiet" ]]; then
    is_quiet=true
  elif [[ "${args[${i}]}" = "--verbose" ]]; then
    verbose_logs=true
    verbose_err="/dev/stderr"
  elif [[ "${args[${i}]}" = "--no-push-config" ]]; then
    push_config=false
  elif [[ "${args[${i}]}" = "--binary-config" ]]; then
    use_binary_config=true
  elif [[ "${args[${i}]}" = "-c" ]]; then
    i=$((i+1))
    config_filepath="${args[${i}]}"
    use_existing_config=true
  elif [[ "${args[${i}]}" = "--no-ftrace" ]]; then
    include_ftrace_defaults=false
    title_args+=("no-ftrace")
  elif [[ "${args[${i}]}" = "--no-atrace" ]]; then
    include_atrace_defaults=false
    title_args+=("no-atrace")
  elif [[ "${args[${i}]}" = "--no-perfetto" ]]; then
    include_perfetto_defaults=false
    title_args+=("no-perfetto")
  elif [[ "${args[${i}]}" = "--symbolize-ksyms" ]]; then
    symbolize_ksyms=true
  elif [[ "${args[${i}]}" = -* ]]; then
    echo "warning: ignoring unknown option ${args[${i}]}"
  else
    cat="${args[${i}]}"
    if [[ "${cat}" == */* ]]; then
      ftrace_events+=("${cat}")
    elif [[ "${cat}" == chrome.* ]]; then
      chrome_categories+="\\\"${cat#"chrome."}\\\","
    else
      categories+=("${cat}")
    fi
  fi
done

# If counters are requested, switch to renderstage mode if also using --gpu2.
if [[ "${include_counters}" == true ]]; then
  if [[ "${include_gpu2}" == true ]] && [[ "${gpu2_low_overhead}" == false ]]; then
    include_counters=false
    include_renderstage_counters=true
  else
    echo "Note: Use --gpu2 with --counters to align counter data with GPU workloads."
  fi
  if [[ "${include_gpu2}" == true ]]; then
    # Enable counter stats by default with --gpu2 --counters.
    print_gpu_counter_stats=true
  fi
fi

# Strip trailing comma:
chrome_categories="${chrome_categories%","}"
chrome_disabled_categories="${chrome_disabled_categories%","}"

if [[ "${is_compare}" == true ]]; then
  if [[ "${#trace_input_files[@]}" -lt 2 ]]; then
    echo "error: --compare requires at least two -f traces."
    exit 1
  fi

  # Build the argument list for sub-calls to xtrace for each trace file.
  compare_counter_stats=()
  for (( i = 0; i < num_args; i++ )); do
    arg="${args[$i]}"
    if [[ "${arg}" == --counter-stats* ]]; then
      compare_counter_stats+=("${arg}")
    fi
  done

  compare_args=("--no-frame-stats" "--no-surface-stats" "--no-open" "--quiet" "--csv-output")

  csv_files=()
  for (( idx = 0; idx < ${#trace_input_files[@]}; idx++ )); do
    file="${trace_input_files[$idx]}"
    csv_file="/tmp/xtrace_compare_${RANDOM}_$$.csv"
    c_stat="--counter-stats"
    if [[ "${#compare_counter_stats[@]}" -gt 0 ]]; then
      if [[ "${idx}" -lt "${#compare_counter_stats[@]}" ]]; then
        c_stat="${compare_counter_stats[$idx]}"
      else
        c_stat="${compare_counter_stats[${#compare_counter_stats[@]}-1]}"
      fi
    fi

    csv_files+=($($cygpathw "${csv_file}"))

    notquiet "Processing $((idx+1)): ${file}..."
    "${0}" "${compare_args[@]}" "${c_stat}" -f "${file}" > "${csv_file}" 2> "${csv_file}.err" &
  done

  wait

  # Print error logs (if any)
  for (( idx = 0; idx < ${#trace_input_files[@]}; idx++ )); do
    file="${trace_input_files[$idx]}"
    error_log=$(cat "${csv_files[$idx]}.err")
    if [[ -n "${error_log}" ]]; then
      echo "Note with ($((idx+1))) ${file}:"
      echo "${error_log}"
    fi
  done

  python_script=$($cygpathw "${xtrace_dir}/scripts/compare_counters.py")
  compare_output=$(${python} "${python_script}" "${trace_input_files[@]}" "--" "${csv_files[@]}")

  dashed_header_line "${compare_output}"
  echo "${compare_output}"

  exit 0
fi


adreno_perfcounter_file="/sys/class/kgsl/kgsl-3d0/perfcounter"

target_name="local"
if [[ "${is_local}" == false ]] && [[ "${from_file}" == false ]]; then
  adb wait-for-device
  is_adb_root && adb wait-for-device

  do_stop_start=false

  if [[ "${enable_gpu}" == true ]]; then
    adb shell "echo 1 > ${adreno_perfcounter_file}"
    adb shell setprop debug.graphics.gpu.profiler.perfetto 1
    if [[ "${enable_gpu_restart_services}" == true ]]; then
      do_stop_start=true
    fi
    echo "GPU tracing is enabled."
    echo ""
    echo " --> Now restart the target app(s) and trace with --gpu1 or --gpu2 and/or --counters."
    echo ""
    echo "NOTE: CPU usage is slightly higher while GPU tracing is enabled, even while not tracing."
  fi

  if [[ "${disable_gpu}" == true ]]; then
    adb shell setprop debug.graphics.gpu.profiler.perfetto 0
    if [[ "${disable_gpu_restart_services}" == true ]]; then
      do_stop_start=true
    fi
    echo "GPU tracing is disabled."
  fi

  if [[ "${disable_dynamic_policy}" == true ]]; then
    orig_dyn_policy=$(adb shell getprop device_config.com_android_xr.com.android.xr.flags.enable_dynamic_policy)
    adb shell setprop device_config.com_android_xr.com.android.xr.flags.enable_dynamic_policy false
    if [[ "${orig_dyn_policy}" != false ]]; then
      do_stop_start=true
    fi
    echo "Dynamic Policy is disabled. Reboot to reenable it."
  fi

  if [[ "${disable_gpu_preemption}" == true ]]; then
    if [[ $(adb shell getprop compositor.high_priority) != 0 ]]; then
      adb shell setprop compositor.high_priority 0
      do_stop_start=true
    fi
    echo "Compositor GPU preemption is disabled. Reboot to reenable it."
  fi

  if [[ "${screen_timeout_ms}" != "0" ]]; then
    echo "Set doff screen timeout to ${screen_timeout_ms} ms."
    adb shell settings put system doff_screen_timeout_ms "${screen_timeout_ms}"
    adb shell input keyevent KEYCODE_WAKEUP
  fi

  if [[ ! -z "${lock_head}" ]]; then
    adb shell setprop cpm.fake_headtracking "${lock_head}"
    adb shell setprop cpm.fake_het_position "0,0,0"
    adb shell setprop cpm.fake_het_orientation "0,0,0,0"
    do_stop_start=true
  fi

  if is_adb_root && [[ "${do_stop_start}" == true ]]; then
    adb shell stop
    sleep 1
    adb shell start
  fi

  if [[ "${skip_tracing}" == true ]]; then
    exit 0
  fi

  if [[ "${from_file}" == false ]]; then
    target_name=$(adb shell getprop ro.product.model)
    [[ -z "${target_name}" ]] &&
      echo "error: no adb device" && exit 1
    is_android=true
  fi

  if [[ "${target_name}" = *SM* ]]; then
    include_android_thermal_config=true
  fi

  if [[ "${include_gpu2}" == true ]]; then
    # There is a bug that causes all GPU events to be lost when the buffer fills
    # up using the RING_BUFFER policy. So we force the DISCARD policy here.
    fill_policy=DISCARD

    if [[ "${target_name}" = *SM* ]]; then
      gpu_perfetto_enabled=$(adb shell getprop debug.graphics.gpu.profiler.perfetto | tr -d '\r')
      [[ ! "${gpu_perfetto_enabled}" == 1 ]] &&
        echo "error: GPU tracing is not enabled." &&
        echo "" &&
        echo " --> Run xtrace --enable-gpu and then restart the target app" &&
        exit 1
    fi
  fi

  if [[ "${include_counters}" == true ]]; then
    perfcounter=$(adb shell cat ${adreno_perfcounter_file} | tr -d '\r')
    [[ ! "${perfcounter}" == 1 ]] &&
      echo "error: GPU counters are not enabled" &&
      echo "" &&
      echo " --> Run xtrace --enable-gpu and then restart the target app" &&
      exit 1
    adb shell "nohup ${gpu_counter_producer} > /dev/null 2>&1 &"
  fi
else
  is_android=false
fi

