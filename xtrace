autoload () {
  did_open=false
  if [[ "${auto_open}" == true ]]; then
    if [[ -z "${ui_sql_path}" ]]; then
      if [[ "${include_gpu}" == true ]] && [[ "${include_gpu2}" == false ]]; then
        ui_sql_path="$($cygpathw ${ui_kgsl_cmds_path})"
      fi
      if [[ "${include_gpu2}" == true ]] && [[ "${gpu2_low_overhead}" == true ]]; then
        ui_sql_path="$($cygpathw ${ui_gpu1_cmds_path})"
      fi
      if [[ "${include_gpu2}" == true ]] && [[ "${gpu2_low_overhead}" == false ]]; then
        ui_sql_path="$($cygpathw ${ui_gpu2_cmds_path})"
      fi
    fi

    openscript="${xtrace_dir}/third_party/perfetto/open-trace.py";
    if [[ -f "${openscript}" ]]; then
      if [[ "${is_big}" == true ]]; then
        echo "Starting trace_processor_shell and perfetto UI..."
        echo ""
        echo "This requires 'Relax Content Security Policy' to be enabled in perfetto UI flags."
        echo "Follow the dialog if you don't have it enabled yet."
        echo ""
        # Get an unused port:
        port=$(${python} -c '
import socket
sock = socket.socket()
sock.bind(("127.0.0.1", 0))
sockname = sock.getsockname()
print(sockname[1])
sock.close()')
        version=$("${host_tools_dir}/trace_processor_shell" -v | grep Perfetto | awk '{print $2}')
        # Adding version makes the UI match the perfetto binaries in third_party/perfetto.
        address="https://ui.perfetto.dev/${version}/#!/?rpc_port=${port}"
        echo "Wait for trace to load (look for \"Trace loaded\"), then open this link:"
        echo ""
        echo "    ----->   ${address}"
        echo ""
        # Launch trace_processor_shell on the trace file:
        ${bg_bash} "${host_tools_dir}/trace_processor_shell -D --http-port ${port} \"${output_file}\"" &
        did_open=true
      else
        if [[ -n "${ui_sql_path}" ]] && [[ ! -f "${ui_sql_path}" ]]; then
          echo "error: file not found: ${ui_sql_path}" >&2
        fi
        ${python} "$($cygpathw "${openscript}")" "${output_file}" "${ui_sql_path}" 2>/dev/null && did_open=true
      fi
    fi

    [[ "${did_open}" == false ]] && [[ -z "${sql_path}" ]] &&
      echo "Open it at https://ui.perfetto.dev/"
  fi
}

run_trace_processor() {
  if [[ "${verbose_sql_logs}" == true ]]; then
    "${host_tools_dir}/trace_processor_shell" -q "$($cygpathw "$1")" "${output_file}"
  else
    "${host_tools_dir}/trace_processor_shell" -q "$($cygpathw "$1")" "${output_file}" \
        2>/tmp/xtrace_trace_processor_shell.stderr
    # Output sql errors to stderr but skip all the earlier output from trace_processor_shell.
    sed -n -e '/Traceback/,$p' /tmp/xtrace_trace_processor_shell.stderr 1>&2
  fi
}

sql_output=""

run_sql_on () {
  local the_sql="$1"
  local title="$2"
  local skip_print="$3"
  if [[ -f "${the_sql}" ]]; then
    if [[ -z "${title}" ]]; then
      title="${the_sql}"
    fi
    if [[ "${skip_print}" != "true" ]]; then
      notquiet ""
      notquiet "Processing ${title}..."
    fi

    local temp_sql_path="/tmp/perfetto-query-${RANDOM}.sql"
    cp "${the_sql}" "${temp_sql_path}"

    # If we have a starting GPU frequency, inject it into the query for a more accurate average.
    if [[ "${gpu_starting_freq_khz}" != 0 ]]; then
      search_string="\\/\\* -- Optionally inject starting GPU frequency sample here -- \\*\\/"
      replace_string="SELECT (SELECT MIN(ts) FROM ftrace_event) AS ts, ${gpu_starting_freq_khz} AS freq_khz UNION ALL"
      if grep -q "${search_string}" "${temp_sql_path}"; then
        verbose "injecting initial GPU frequency for query: ${gpu_starting_freq_khz}"
        sed -i -e "s@${search_string}@${replace_string}@g" "${temp_sql_path}"
      fi
    fi

    for (( i = 0; i < ${#custom_stats[@]}; i++ ));
    do
      verbose "  adding ${custom_stats[${i}]} to ${temp_sql_path}"
      search_string="/\\* template stat insert \\*/"
      replace_string="( SELECT AVG(dur) / 1000000.0 FROM thread_slice WHERE name LIKE '${custom_stats[${i}]}' AND upid = gpu_pids.upid ) AS '${custom_stats[${i}]}',${search_string}"
      sed -i -e "s@${search_string}@${replace_string}@g" "${temp_sql_path}"
    done

    if [[ "${is_filtered_query_output}" == true ]]; then
      sql_output=$(run_trace_processor "${temp_sql_path}" | sed 's/\"//g' | sed 's/\[NULL\]/-/g' | sed '/^$/d')
      sql_print=$(echo "${sql_output}" | column -s, -t)
    else
      sql_output=$(run_trace_processor "${temp_sql_path}" | sed '/^$/d')
      sql_print="${sql_output}"
    fi

    if [[ "${skip_print}" != "true" ]]; then
      dashed_header_line "${sql_print}"
      echo "${sql_print}"
    fi
  else
    echo "error: sql query file not found: ${the_sql}"
  fi
}

surface_stats_output=""

run_surface_sql() {
  if [[ -n "${surface_stats_output}" ]]; then
    return
  fi
  run_sql_on "${xtrace_dir}/queries/surface_stats.sql" "--surface-stats" "${suppress_surface_stats}"
  surface_stats_output="${sql_output}"
}

run_counters_sql () {
  local temp_sql_path="/tmp/gpu2_counters-${RANDOM}.sql"
  cp "${xtrace_dir}/queries/gpu2_counters.sql" "${temp_sql_path}"
  local counter_stats_title="--counter-stats"

  if [[  -z "${gpu_counter_stats_filter}" ]]; then
    run_surface_sql
    read top_proc top_index <<< $(echo "${surface_stats_output}" | sed 's/\"//g' | awk -F, '
      NR==1 {
        for(i=1;i<=NF;i++) {
          if($i=="ProcessName") proc_idx=i;
          if($i=="SurfaceID") idx_idx=i;
        }
      }
      NR>1 && proc_idx && $proc_idx != "" {
        print $proc_idx, $idx_idx; exit
      }
    ')

    if [[ -n "${top_proc}" ]]; then
      gpu_counter_stats_filter="${top_proc},${top_index}"
      if (( $(echo "${surface_stats_output}" | wc -l) > 2 )); then
        counter_stats_title="--counter-stats=${gpu_counter_stats_filter}"
        if [[ "${suppress_surface_stats}" == true ]]; then
          echo "  Auto-selected: ${counter_stats_title}" >&2
          echo "  Is that the right one? Confirm with --surface-stats." >&2
          echo "  To be explicit with --compare on traces with multiple surfaces," >&2
          echo "  add a --counter-stats=... to the command line for each -f arg" >&2
        fi
      fi
    else
      echo "Warning: No GPU Surface events found."
    fi
  fi

  if [[ -n "${gpu_counter_stats_filter}" ]]; then
    sql_filter=""
    if [[ "${gpu_counter_stats_filter}" == *,* ]]; then
      # eg: --counter-stats=com.company.app,1/2
      app_pattern="${gpu_counter_stats_filter%,*}"
      idx_pattern="${gpu_counter_stats_filter#*,}"
    elif [[ "${gpu_counter_stats_filter}" == */* ]]; then
      # eg: --counter-stats=1/2
      app_pattern=""
      idx_pattern="${gpu_counter_stats_filter}"
    else
      # eg: --counter-stats=com.company.app
      app_pattern="${gpu_counter_stats_filter}"
      idx_pattern=""
    fi

    if [[ -n "${app_pattern}" ]]; then
      # SQLite GLOB uses * for wildcards, not %. Strip any % the user might have passed.
      app_pattern="${app_pattern//%/}"
      # Ensure it has exactly one * at the start and end
      app_pattern="*${app_pattern#\*}"
      app_pattern="${app_pattern%\*}*"
      sql_filter+=" AND EXTRACT_ARG(arg_set_id, 'description') GLOB '${app_pattern}' "
    fi

    if [[ -n "${idx_pattern}" ]]; then
      idx="${idx_pattern%/*}"
      total="${idx_pattern#*/}"
      idx=$((idx - 1))
      sql_filter+=" AND EXTRACT_ARG(arg_set_id, 'name') GLOB 'Surface *' AND CAST(SUBSTR(EXTRACT_ARG(arg_set_id, 'name'), 9) AS INT) % ${total} = (${idx}%${total}) "
    fi

    search_string="\\/\\* template surface filter \\*\\/"
    sed -i -e "s@${search_string}@${sql_filter}@g" "${temp_sql_path}"

    search_string="\\/\\* template filter active \\*\\/ 0 = 0"
    sed -i -e "s@${search_string}@1 = 0@g" "${temp_sql_path}"

    search_string="\\/\\* template target filter processing \\*\\/ name IN ('Binning', 'Render', 'Dispatch', 'Compute')"
    sed -i -e "s@${search_string}@name = 'Surface' ${sql_filter}@g" "${temp_sql_path}"
  fi

  run_sql_on "${temp_sql_path}" "${counter_stats_title}"
}

run_sql () {
  if [[ -n "${sql_path}" ]]; then
    run_sql_on "${sql_path}"
  fi

  # Enable builtin frame stats query.
  if [[ "${print_frame_stats}" == true ]]; then
    run_sql_on "${xtrace_dir}/queries/${gpu_stats_filename}" "--frame-stats"
  fi

  if [[ "${print_cpu_top}" == true ]]; then
    run_sql_on "${xtrace_dir}/queries/cpu_top.sql" "--cpu-top"
  fi

  if [[ "${print_surface_stats}" == true ]]; then
    run_surface_sql
  fi

  if [[ "${print_gpu_counter_stats}" == true ]]; then
    run_counters_sql
  fi
}

if [[ "${from_file}" == true ]]; then
  if [[ ! -f "${output_file}" ]]; then
    echo "error: file not found: ${output_file}" >&2
    exit 1
  fi

  gpu_starting_freq_khz=$(grep --binary-files=text -E -o "phony_start_gpu_freq/.{0,6}" "${output_file}" | \
                          sed 's/phony_start_gpu_freq\///')
  if ! [[ "${gpu_starting_freq_khz}" =~ ^[0-9]+$ ]]; then # check if we got a number
    gpu_starting_freq_khz=0
  else
    verbose "Found initial GPU frequency: ${gpu_starting_freq_khz}"
  fi

  run_sql

  # Autoload by default if there was no explicitly set sql query.
  if [[ -z "${sql_path}" ]]; then
    autoload
  fi

  exit 0
fi

set_title() {
  title_args=$(echo "${title_args[@]}" | tr ' ' '-')
  if [[ ! -z "${output_args_file}" ]]; then
    echo "${title_args}" > "${output_args_file}"
  fi

  if [[ -d "${output_file}" ]]; then
    output_file=$($cygpathw "${output_file}/trace-${title_args}-${now}.perfetto")
  elif [[ -z "${output_file}" ]]; then
    output_file="./trace-${title_args}-${now}.perfetto"
  fi

  if [[ -f "${output_file}" ]]; then
    rm "${output_file}"
  fi
  if touch "${output_file}"; then
    rm "${output_file}"
  else
    echo "error: output file is not writable: ${output_file}"
    exit 1
  fi
}

if [[ "${is_local}" == false ]] && [[ "${lock_frequencies}" == true ]]; then
  orig_dyn_policy=$(adb shell getprop device_config.com_android_xr.com.android.xr.flags.enable_dynamic_policy)
  if [[ "${orig_dyn_policy}" != false ]]; then
    echo "Warning: Dynamic Policy can override --lock-frequencies."
    echo "         Run 'xtrace --disable-dynamic-policy' for more reliable results."
  fi

  # Disable SSRM
  adb shell am broadcast -a com.salab.act.intent.SSRM --ez pmic_sensing_limit true > /dev/null 2>&1

  gpu_level=5  # 599
  cpu_freq=1920000
  ddr_freq=2736

  # Lock GPU frequency
  orig_gpu_min_pwrlevel=$(adb shell cat /sys/class/kgsl/kgsl-3d0/min_pwrlevel)
  orig_gpu_max_pwrlevel=$(adb shell cat /sys/class/kgsl/kgsl-3d0/max_pwrlevel)
  adb shell "echo ${gpu_level} > /sys/class/kgsl/kgsl-3d0/min_pwrlevel"
  adb shell "echo ${gpu_level} > /sys/class/kgsl/kgsl-3d0/max_pwrlevel"
  adb shell "echo ${gpu_level} > /sys/class/kgsl/kgsl-3d0/min_pwrlevel"
  adb shell "echo ${gpu_level} > /sys/class/kgsl/kgsl-3d0/max_pwrlevel"

  # Lock CPU frequency
  orig_cpu1_min=$(adb shell cat /sys/devices/system/cpu/cpufreq/policy0/scaling_min_freq)
  orig_cpu1_max=$(adb shell cat /sys/devices/system/cpu/cpufreq/policy0/scaling_max_freq)
  orig_cpu2_min=$(adb shell cat /sys/devices/system/cpu/cpufreq/policy2/scaling_min_freq)
  orig_cpu2_max=$(adb shell cat /sys/devices/system/cpu/cpufreq/policy2/scaling_max_freq)
  adb shell "echo ${cpu_freq} > /sys/devices/system/cpu/cpufreq/policy0/scaling_max_freq"
  adb shell "echo ${cpu_freq} > /sys/devices/system/cpu/cpufreq/policy0/scaling_min_freq"
  adb shell "echo ${cpu_freq} > /sys/devices/system/cpu/cpufreq/policy2/scaling_max_freq"
  adb shell "echo ${cpu_freq} > /sys/devices/system/cpu/cpufreq/policy2/scaling_min_freq"

  # Lock DDR frequency
  if [[ -z "$(adb shell mount | grep debug)" ]]; then
    # Mount debugfs if it's not already mounted
    adb shell mount -t debugfs debugfs /sys/kernel/debug
    if [[ $? -ne 0 ]]; then
      echo "Error mounting debugfs: can't set ddr freq."
    fi
  fi
  adb shell "echo \"{class: ddr, res: fixed, val: $((${ddr_freq} - 50))}\" > /sys/kernel/debug/aoss_send_message"

  # Print frequencies
  sleep 1
  gpu_freq=$(($(adb shell cat /sys/class/kgsl/kgsl-3d0/devfreq/cur_freq) / 1000))
  cpu1_freq=$(adb shell cat /sys/devices/system/cpu/cpufreq/policy0/scaling_cur_freq)
  cpu2_freq=$(adb shell cat /sys/devices/system/cpu/cpufreq/policy2/scaling_cur_freq)
  ddr_freq=$(($(adb shell cat /sys/kernel/debug/clk/measure_only_mccc_clk/clk_measure) / 1000))

  echo "Lock frequencies: GPU:${gpu_freq} CPU:${cpu1_freq},${cpu2_freq} DDR:${ddr_freq}"
fi

# Capture starting GPU frequency.
if [[ "${is_local}" == false ]]; then
  raw_freq=$(adb shell cat /sys/class/kgsl/kgsl-3d0/devfreq/cur_freq 2> /dev/null | tr -d '\r' | tr -d ' ')
  if [[ "$raw_freq" =~ ^[0-9]+$ ]]; then
    gpu_starting_freq_khz=$((raw_freq / 1000))
  else
    gpu_starting_freq_khz=0
  fi

  # Inject a phony disabled category with the starting GPU frequency for later reference.
  disabled_categories+=("phony_start_gpu_freq/${gpu_starting_freq_khz}")
fi

# Write config file.
if [[ "${use_existing_config}" == true ]]; then
  config_filebasename=$(basename "${config_filepath}")
  # get filename without extension
  config_filebasename=${config_filebasename%.*}
  title_args+=("config_${config_filebasename}")
else
  write_config_file
fi

set_title

verbose "Using config: ${config_filepath}"

if [[ "${is_local}" == true ]]; then
  if [[ "${time_ms}" == "0" ]]; then
    echo "Press Ctrl-C to stop tracing..."
  fi

  "${perfetto}" -c "$($cygpathw $config_filepath)" --txt \
      -o "${output_file}" > /dev/null || exit 1
  du -hs "${output_file}"
  autoload
  exit 0
fi

if [[ "${use_binary_config}" == true ]]; then
  "protoc" --encode=perfetto.protos.TraceConfig \
          "--proto_path=$($cygpathw $(dirname $0))" \
          "$($cygpathw $(dirname $0)/third_party/perfetto/perfetto_config.proto)" \
          < "${config_filepath}" \
          > "${config_filepath}.bin" \
      || exit 1
  config_filepath="${config_filepath}.bin"
else
  extra_args="--txt"
fi

android_config="/data/misc/perfetto-configs/config"
android_trace="//data/misc/perfetto-traces/trace"

# Stop old trace sessions and delete old trace files to avoid ownership errors.
adb shell -x "pkill -x perfetto; rm -f ${android_trace}; " > /dev/null 2>&1

# Kick off background perfetto trace.
if adb push $($cygpathw ${config_filepath}) ${android_config} > /dev/null 2>&1 ; then
  if ! perfetto_pid=$(adb shell perfetto -c ${android_config} "${extra_args}" \
                    --background --o "${android_trace}" 2> ${verbose_err}); then
    echo "perfetto error: try again with --verbose to see errors."
    exit 1
  fi
else
  [[ "${push_config}" == true ]] &&
      echo "Warning: could not push config, so retry with --no-push-config if there are errors"
  if ! perfetto_pid=$(adb shell perfetto -c - "${extra_args}" \
                      --background --o "${android_trace}" < "${config_filepath}"); then
    exit 1
  fi
fi

perfetto_pid=$(echo "$perfetto_pid" | tr -d '\r')

get_time_ns () {
  # date +%s%N doesn't work on Mac.
  perl -MTime::HiRes=time -e 'printf "%.0f\n", time * 1000000000'
}

cur_time_ns=$(get_time_ns)

# Wait for timeout or interrupt.
time_string='... press Ctrl-C to stop'
[[ "${time_ms}" != "0" ]] && time_string=" for ${time_ms} ms..."
[[ "${time_ms}" == "0" ]] && time_ms=$((24*60*60*1000)) # 24 hours by default.
wait_ns="${time_ms}000000"
end_time_ns=$((cur_time_ns + wait_ns))
stop_waiting () { end_time_ns="${cur_time_ns}" ; }
trap "echo ; stop_waiting" SIGINT
trap "stop_waiting" SIGUSR1
echo "Tracing ${target_name}${time_string}"
# Note this sleep is intentionally short because parent script may
# send us a SIGUSR1 that we only handle in between sleeps.
while [[ ( $(get_time_ns) < "${end_time_ns}" ) ]]; do sleep 0.1; done
trap - SIGINT SIGUSR1

# Kill all perfetto processes and wait for them to finish.
echo "Please wait: copying trace from ${target_name}..."

# Wait for device in case it was unplugged during the trace.
adb wait-for-device

# Wait for trace completion.
# Now using inotifyd instead of attach, to be sure the file is fully written.
# Android 16 changed the syntax from ::w to :w
inotify_setup='inotify_suffix="::w"; [[ $(getprop ro.build.version.release) -ge 16 ]] && inotify_suffix=":w"'
adb shell "${inotify_setup}; inotifyd - ${android_trace}\$inotify_suffix | head -n0 & kill ${perfetto_pid} ; wait ; \
    pkill -x ${gpu_counter_producer}"

if ! adb pull ${android_trace} ${output_file} > /dev/null 2>&1; then
  sleep 1
  adb wait-for-device
  if ! adb pull ${android_trace} ${output_file}; then
    sleep 1
    adb wait-for-device
    adb pull ${android_trace} ${output_file} \
        || { echo "error: failed to adb pull ${android_trace} ${output_file}" ; exit 1; }
  fi
fi
du -hs "${output_file}"
autoload

if [[ "${screenshot}" == true ]]; then
  echo "Capturing screenshot..."
  previous_raw=$(adb shell getprop cpm.raw_capture)
  is_adb_root && adb shell setprop cpm.raw_capture true
  adb exec-out screencap -p > "${output_file}.png"
  is_adb_root && [[ "${previous_raw}" != true ]] && adb shell setprop cpm.raw_capture false
  du -hs "${output_file}.png"
fi

if [[ "${lock_frequencies}" == true ]]; then
  # Restore previous frequencies.
  adb shell "echo $orig_gpu_min_pwrlevel > /sys/class/kgsl/kgsl-3d0/min_pwrlevel"
  adb shell "echo $orig_gpu_max_pwrlevel > /sys/class/kgsl/kgsl-3d0/max_pwrlevel"

  adb shell "echo $orig_cpu1_max > /sys/devices/system/cpu/cpufreq/policy0/scaling_max_freq"
  adb shell "echo $orig_cpu1_min > /sys/devices/system/cpu/cpufreq/policy0/scaling_min_freq"
  adb shell "echo $orig_cpu2_max > /sys/devices/system/cpu/cpufreq/policy2/scaling_max_freq"
  adb shell "echo $orig_cpu2_min > /sys/devices/system/cpu/cpufreq/policy2/scaling_min_freq"

  adb shell "echo \"{class: ddr, res: fixed, val: 0}\" > /sys/kernel/debug/aoss_send_message"
fi

run_sql
